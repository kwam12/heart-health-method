---
---
<section id="join" class="py-20 bg-gradient-to-br from-blue-900 to-blue-800 text-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-4xl md:text-5xl font-bold mb-6">Ready to take control of your heart health?</h2>
    <p class="text-xl md:text-2xl text-blue-100 mb-4">
      Join thousands who've improved their numbers naturally.
    </p>
    <p class="text-lg text-blue-200 mb-10">
      Start with our free Heart Health Assessment and get your personalized protocol.
    </p>

    <!-- Email Form -->
    <div class="max-w-md mx-auto mb-8">
      <form class="flex flex-col sm:flex-row gap-3" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
        <input 
          type="email" 
          name="email"
          placeholder="Enter your email" 
          required
          class="flex-1 px-5 py-4 rounded-full text-gray-900 focus:outline-none focus:ring-2 focus:ring-white text-lg"
        />
        <button 
          type="submit"
          class="bg-red-600 text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-red-700 transition shadow-lg"
        >
          Get Started Free
        </button>
      </form>
    </div>

    <p class="text-sm text-blue-200 mb-8">No credit card required. Unsubscribe anytime.</p>

    <!-- Trust indicators -->
    <div class="flex flex-wrap items-center justify-center gap-6 text-sm text-blue-200">
      <div class="flex items-center">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
        </svg>
        Evidence-Based Protocols
      </div>
      <div class="flex items-center">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
        </svg>
        Doctor-Developed
      </div>
      <div class="flex items-center">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
        </svg>
        15,000+ Success Stories
      </div>
    </div>
  </div>
</section>
