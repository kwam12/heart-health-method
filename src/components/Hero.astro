---
---
<section class="pt-32 pb-20 bg-gradient-to-b from-blue-50 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-4xl mx-auto">
      <h1 class="text-5xl md:text-6xl font-bold text-gray-900 leading-tight mb-6">
        Lower your blood pressure.<br/>
        <span class="text-blue-900">Naturally.</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-600 mb-4 max-w-3xl mx-auto">
        The evidence-based method for people 40+ who want to improve their heart health.
      </p>
      <p class="text-lg text-gray-500 mb-10">
        Fix the root causes with simple, sustainable habits. No extreme diets. No medication dependency.
      </p>
      
      <!-- Email Form -->
      <div class="max-w-md mx-auto mb-8">
        <form class="flex flex-col sm:flex-row gap-3" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
          <input 
            type="email" 
            name="email"
            placeholder="Enter your email" 
            required
            class="flex-1 px-5 py-4 rounded-full border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 text-lg"
          />
          <button 
            type="submit"
            class="bg-red-600 text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-red-700 transition shadow-lg"
          >
            Get Free Guide
          </button>
        </form>
        <p class="text-sm text-gray-500 mt-3">Join 15,000+ people improving their heart health. Unsubscribe anytime.</p>
      </div>

      <!-- Social Proof -->
      <div class="flex items-center justify-center gap-8 text-sm text-gray-600">
        <div class="flex items-center">
          <span class="text-yellow-500 text-lg">★★★★★</span>
          <span class="ml-2 font-medium">4.9</span>
        </div>
        <div class="flex items-center">
          <span class="text-blue-900 font-bold text-lg">15,000+</span>
          <span class="ml-2">lives improved</span>
        </div>
      </div>
    </div>
  </div>
</section>
